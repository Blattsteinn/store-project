<!-- app/views/carts/show.html.erb -->
<h1>Your Cart</h1>

<% if @cart_items.any? %>
  <table>
    <thead>
      <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Total</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @cart_items.each do |item| %>
        <tr>
          <td><%= item.product.title %></td>
          <td><%= item.product.pricing %></td>
          <td><%= item.quantity %></td>
          <td><%= item.product.pricing * item.quantity %></td>
          <td><%= button_to "Remove", cart_item_path(item), method: :delete %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

<% else %>
  <p>Your cart is empty</p>
<% end %>