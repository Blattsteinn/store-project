<% content_for :head do %>
  <%= stylesheet_link_tag "support_messages" %>
<% end %>

<div class="sm-show">
  <%= link_to "← Back to all messages", support_messages_path, class: "sm-back-link" %>

  <div class="card">
    <h2>Support Message #<%= @support_message.id %></h2>

    <div class="sm-item">
      <span class="sm-label">Title</span>
      <span class="sm-val"><%= @support_message.title %></span>
    </div>

    <div class="sm-item">
      <span class="sm-label">Email</span>
      <span class="sm-val"><%= @support_message.email %></span>
    </div>

    <div class="sm-item">
      <span class="sm-label">Order ID</span>
      <span class="sm-val"><%= @support_message.order_id || "—" %></span>
    </div>

    <div class="sm-item">
      <span class="sm-label">Status</span>
      <span class="sm-val"><span class="sm-status sm-status-<%= @support_message.status %>"><%= @support_message.status %></span></span>
    </div>

    <div class="sm-item">
      <span class="sm-label">Created</span>
      <span class="sm-val"><%= @support_message.created_at.strftime("%b %d, %Y %H:%M") %></span>
    </div>

    <div class="sm-body">
      <%= @support_message.message %>
    </div>
  </div>

  <div class="sm-actions">
    <%= button_to "Close case", support_message_path(@support_message), method: :patch, params: { status: "closed" }, form_class: "inline-form" %>
    <%= button_to "Open case", support_message_path(@support_message), method: :patch, params: { status: "open" }, form_class: "inline-form" %>
  </div>
</div>