<div id="dashboard-container">
  <%= render "dashboard/sidebar" %>

  <main id="dashboard-main">
    <header class="dashboard-page-header">
      <h1>Support Message #<%= @support_message.id %></h1>
      <%= link_to "← Back to all messages", support_messages_path, class: "btn-sm btn-sm-muted" %>
    </header>

    <div class="dashboard-card">
      <div class="card-header"><h3>Message Details</h3></div>
      <div class="card-body">
        <dl class="detail-list">
          <div class="detail-row">
            <dt>Title</dt>
            <dd><%= @support_message.title %></dd>
          </div>
          <div class="detail-row">
            <dt>Email</dt>
            <dd><%= @support_message.email %></dd>
          </div>
          <div class="detail-row">
            <dt>Order ID</dt>
            <dd><%= @support_message.order_id || "—" %></dd>
          </div>
          <div class="detail-row">
            <dt>Status</dt>
            <dd><span class="status-badge status-<%= @support_message.status %>"><%= @support_message.status %></span></dd>
          </div>
          <div class="detail-row">
            <dt>Created</dt>
            <dd><%= @support_message.created_at.strftime("%B %d, %Y at %H:%M") %></dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="dashboard-card">
      <div class="card-header"><h3>Message</h3></div>
      <div class="card-body">
        <div class="feedback-body"><%= simple_format(@support_message.message) %></div>
      </div>
    </div>

    <div class="dashboard-card">
      <div class="card-header"><h3>Actions</h3></div>
      <div class="card-body">
        <div class="action-group">
          <%= button_to "Close case", support_message_path(@support_message), method: :patch, params: { status: "closed" }, class: "btn-sm" %>
          <%= button_to "Open case", support_message_path(@support_message), method: :patch, params: { status: "open" }, class: "btn-sm" %>
        </div>
      </div>
    </div>
  </main>
</div>