<h1>Support Messages</h1>

<table border="1" cellpadding="6" cellspacing="0">
  <thead>
    <tr>
      <th>ID</th>
      <th>Title</th>
      <th>Email</th>
      <th>Order ID</th>
      <th>Status</th>
      <th>Created At</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @support_messages.each do |message| %>
      <tr>
        <td><%= message.id %></td>
        <td><%= message.title %></td>
        <td><%= message.email %></td>
        <td><%= message.order_id %></td>
        <td><%= message.status %></td>
        <td><%= message.created_at.strftime("%b %d, %Y") %></td>
        <td><%= link_to "View", support_message_path(message) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
