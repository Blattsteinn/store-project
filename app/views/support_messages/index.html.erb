<div id="dashboard-container">
  <%= render "dashboard/sidebar" %>

  <main id="dashboard-main">
    <header class="dashboard-page-header">
      <h1>Support Messages</h1>
      <p class="text-muted"><%= @support_messages.count %> messages</p>
    </header>

    <div class="dashboard-card">
      <div class="card-body" style="padding: 0;">
        <table class="dash-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>Email</th>
              <th>Order ID</th>
              <th>Status</th>
              <th>Created</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @support_messages.each do |message| %>
              <tr>
                <td>#<%= message.id %></td>
                <td><%= truncate(message.title, length: 50) %></td>
                <td><%= message.email %></td>
                <td><%= message.order_id || "—" %></td>
                <td><span class="status-badge status-<%= message.status %>"><%= message.status %></span></td>
                <td><%= message.created_at.strftime("%b %d, %Y") %></td>
                <td><%= link_to "View", support_message_path(message), class: "btn-sm btn-sm-muted" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>