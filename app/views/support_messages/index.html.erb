<% content_for :head do %>
  <%= stylesheet_link_tag "support_messages" %>
<% end %>

<div class="sm-index">
  <div class="sm-header">
    <h1>Support Messages</h1>
  </div>

  <div class="sm-table-card">
    <table class="sm-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Title</th>
          <th>Email</th>
          <th>Order ID</th>
          <th>Status</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @support_messages.each do |message| %>
          <tr>
            <td>#<%= message.id %></td>
            <td><%= truncate(message.title, length: 50) %></td>
            <td><%= message.email %></td>
            <td><%= message.order_id || "—" %></td>
            <td><span class="sm-status sm-status-<%= message.status %>"><%= message.status %></span></td>
            <td><%= message.created_at.strftime("%b %d, %Y") %></td>
            <td><%= link_to "View", support_message_path(message), class: "sm-link" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>