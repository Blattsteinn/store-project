<h1> New of support messages </h1>

<% if @support_message.errors.any? %>
      <div class="feedback-errors">
        <strong>Please fix the following:</strong>
        <ul>
          <% @support_message.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

<%= form_with model: @support_message do |form| %>

    <div>
        <%= form.label :title %> <br>
        <%= form.text_field :title %>
    </div>

    <div>
        <%= form.label :email %> <br>
        <%= form.email_field :email %>
    </div>

    <div>
        <%= form.label :order_id %> <br>
        <%= form.text_field :order_id %>
    </div>

    <div>
        <%= form.label :message %> <br>
        <%= form.textarea :message %>
    </div>

    <%= form.submit %>
<% end %>