<turbo-frame id="saved-message">
</turbo-frame>

<%= link_to "← Back to products", products_path, class: "product-back-link" %>

<div class="ps" data-controller="product-view">
  <div class="ps-header">
    <h1><%= @product.title %></h1>
  </div>

  <%# Product Image %>
  <div class="card ps-image-card">
    <% @product.product_images.each do |image| %>
      <%= image_tag image.image, alt: @product.title %>
      <% break %>
    <% end %>
  </div>

  <%# Description %>
  <div class="card">
    <h2>Description</h2>
    <div class="ps-description">
      <%= raw markdown(@product.description) %>
    </div>
  </div>

  <%# Variants %>
  <div class="card">
    <h2>Options</h2>
    <%= form_with local: true do |form| %>
      <% @product.variants.each do |variant| %>
        <% next if variant.stock <= 0 %>

        <label class="ps-variant">
          <%= form.radio_button :product_id, variant.id,
            data: {
              action: "change->product-view#update_form_values",
              stock: variant.stock,
              variant_id: variant.id,
              product_id: @product.id,
              price: variant.price,
              selected: false,
            } %>
          <div class="variant-info">
            <p><%= variant.title %></p>
            <p class="variant-description"><%= variant.description %></p>
          </div>
          <div class="variant-meta">
            <p class="variant-price"><%= convert_from_cents(variant.price) %> EUR</p>
            <p class="variant-stock"><%= variant.stock %> in stock</p>
          </div>
        </label>
      <% end %>
    <% end %>
  </div>

  <%# Instant Payment (hidden until variant selected) %>
  <div class="card" id="instant-payment" data-product-view-target="entireDiv" hidden>
    <h2>Checkout</h2>

    <div class="ps-qty-row">
      <p class="ps-price" data-product-view-target="price"></p>
      <div class="ps-qty-controls">
        <button type="button" data-action="click->product-view#decrease" class="ps-qty-btn">−</button>
        <%= form_with do |form| %>
          <%= form.number_field :quantity, max: 1, value: 1, min: 1, readonly: true,
            data: {
              product_view_target: "variantMax",
              action: "change->product-view#update_quantity",
            } %>
        <% end %>
        <button type="button" data-action="click->product-view#increase" class="ps-qty-btn">+</button>
      </div>
    </div>

    <%= form_with url: orders_path, method: :post, data: { turbo: false } do |form| %>
      <%= form.hidden_field :variant_id, data: { product_view_target: "stripeVariantId" } %>
      <%= form.hidden_field :quantity, value: 1, data: { product_view_target: "stripeQuantity" } %>

      <div class="ps-field">
        <%= form.email_field :email, placeholder: "Enter your email", required: true, maxlength: 255, minlength: 5 %>
      </div>

      <%= button_tag type: 'submit', class: 'ps-stripe-btn' do %>
        <%= image_tag 'stripe.png', class: 'stripe-logo', alt: 'Pay with Stripe' %>
      <% end %>
      <p class="ps-payment-note">Pay by card, Venmo, Apple Pay, Google Pay</p>
    <% end %>
  </div>
</div>