
<%= link_to "Back to products", products_path %>


<div id="product-view-container">
  <h1><%= @product.title %></h1>
  

  <div id="product-view-first-column">
    
    <div>
      <% @product.product_images.each do |image| %>
          <%= image_tag image.image, alt: @product.title, style: "max-width: 300px;" %>
      <% end %>
    </div>


    <p> <%= @product.description %>  </p>
    
    <p>Payment Type: <%= @product.payment_type %> </p>
    <p>Deliverables:  <%= @product.deliverables %> </p>
    <p>Visibility:    <%= @product.visibility %>   </p>
  </div>

  <div id="product-view-second-column">
    <p><%= @product.pricing %> (EUR)</p>
    <p>Stock: <%= @product.stock %></p>

    <%= form_with url: cart_items_path, method: :post do |f| %>
      <%= f.hidden_field :product_id, value: @product.id %>

      <%= f.label :quantity, "Quantity" %>
      <%= f.number_field :quantity, value: 1, min: 1 %>

      <%= f.submit "Add To Cart" %>
    <% end %>
  </div>

</div>