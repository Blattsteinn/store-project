<% images = @product.product_images.to_a %>
<% min_price = convert_from_cents(@product.variants.where.not(stock: 0).minimum(:price)) %>

<div class="product-hero-wrapper">

  <%# Blurred background image (like card design) %>
  <div class="hero-blur-bg">
    <% if images.any? %>
      <%= image_tag images.first.image, alt: "" %>
    <% end %>
  </div>

  <%= link_to "← Back", game_products_path(@game.name), class: "hero-back-link" %>

  <div class="product-hero-stage">
    <% if images.any? %>
      <%= image_tag images.first.image, class: "product-hero-bg", alt: @product.title, id: "hero-bg-image" %>
    <% end %>
    <div class="product-hero-overlay"></div>

    <div class="product-hero-content">
      <span class="hero-badge"><%= @game.name %></span>
      <h1><%= @product.title %></h1>
    </div>

    <div class="product-hero-cta-row">
      <a href="#hero-purchase" class="hero-cta-primary">
        Buy Now
      </a>
      <a href="#hero-description" class="hero-cta-secondary">Learn More</a>
    </div>

  </div>

  <%# ---- Detail section ---- %>
  <div class="product-hero-detail">
    <div class="product-hero-detail-grid">

      <%# Description %>
      <div class="hero-desc-panel" id="hero-description">
        <h2>About this product</h2>
        <div class="hero-desc-body">
          <%= raw markdown(@product.description) %>
        </div>

        <%# Gallery — same carousel as regular show view %>
        <% if images.size > 1 %>
          <div id="product-image-container" data-controller="product-view" style="margin-top: 2rem;">
            <% images.each do |image| %>
              <%= image_tag image.image, alt: @product.title,
                  data: { product_view_target: "image", action: "click->product-view#openLightbox" },
                  style: "cursor: zoom-in" %>
            <% end %>

            <button type="button" class="carousel-arrow carousel-prev" data-action="click->product-view#prevImage" aria-label="Previous image">‹</button>
            <button type="button" class="carousel-arrow carousel-next" data-action="click->product-view#nextImage" aria-label="Next image">›</button>

            <div class="carousel-dots">
              <% images.each_with_index do |_, i| %>
                <button type="button" class="carousel-dot <%= 'active' if i == 0 %>"
                        data-product-view-target="dot"
                        data-index="<%= i %>"
                        data-action="click->product-view#goToImage"
                        aria-label="Image <%= i + 1 %>"></button>
              <% end %>
            </div>

            <span class="carousel-counter" data-product-view-target="imageCounter">1 / <%= images.size %></span>
          </div>
        <% end %>
      </div>

      <%# Purchase panel %>
      <div class="hero-purchase-panel" id="hero-purchase">
        <p class="panel-title">Select variant &amp; purchase</p>

        <%= form_with url: orders_path, method: :post, data: { turbo: false },
              html: { class: "hero-purchase-form" } do |form| %>

          <div class="hero-variant-list">
            <% @product.variants.each do |variant| %>
              <% next if variant.stock <= 0 %>
              <label class="hero-variant-option" data-price="<%= convert_from_cents(variant.price) %>">
                <%= form.radio_button :variant_id, variant.id, required: true %>
                <div class="hero-variant-info">
                  <p class="v-name"><%= variant.title %></p>
                  <% if variant.description.present? %>
                    <p class="v-desc"><%= variant.description %></p>
                  <% end %>
                </div>
                <div>
                  <p class="hero-variant-price"><%= convert_from_cents(variant.price) %>€</p>
                  <p class="hero-variant-stock"><%= variant.stock %> in stock</p>
                </div>
              </label>
            <% end %>
          </div>

          <%= form.hidden_field :quantity, value: 1 %>

          <%= form.label :email, "Email (required)" %>
          <%= form.email_field :email, placeholder: "you@example.com", required: true %>

          <%= form.label :discord, "Discord (optional)" %>
          <%= form.text_field :discord, placeholder: "username" %>

          <%= button_tag type: 'submit', class: 'hero-stripe-btn' do %>
            <%= image_tag 'stripe.png', alt: 'Pay with Stripe', style: "height:20px" %>
          <% end %>

          <p class="hero-payment-methods">
            Card · Apple Pay · Google Pay
          </p>
        <% end %>
      </div>
      
    </div>
  </div>
</div>
