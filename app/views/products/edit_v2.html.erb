<% content_for :head do %>
  <%= stylesheet_link_tag "product/edit_v2" %>
<% end %>

<%# ── Sticky toolbar ── %>
<div class="edit-v2-toolbar">
  <h2>Edit — <%= @product.title.truncate(40) %></h2>
  <div class="edit-v2-toolbar-actions">
    <%= link_to "Cancel", dashboard_products_path, class: "edit-v2-btn-cancel" %>
    <button type="submit" form="edit-product-form" class="edit-v2-btn-save">Save Changes</button>
  </div>
</div>

<div class="edit-v2">

  <%# ═══ LEFT: Editor ═══ %>
  <div class="edit-v2-editor">

    <% if flash[:fail_edit] %>
      <div class="edit-v2-flash edit-v2-flash-error"><%= flash[:fail_edit] %></div>
    <% end %>

    <%= form_with model: @product, multipart: true, id: "edit-product-form" do |form| %>

      <%# ── General ── %>
      <div class="edit-v2-section">
        <div class="edit-v2-section-header">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          General
        </div>

        <div class="edit-v2-row">
          <div class="edit-v2-field" style="flex: 2">
            <%= form.label :title, "Product title" %>
            <%= form.text_field :title, placeholder: "e.g. 8,000 Dragon Stones Account" %>
          </div>
          <div class="edit-v2-field">
            <%= form.label :visibility %>
            <%= form.select :visibility, [
              ["● Live", "live"],
              ["○ Hidden", "hidden"],
              ["◐ Private", "private"],
              ["◌ On Hold", "on_hold"]] %>
          </div>
        </div>

        <div class="edit-v2-field">
          <%= form.label :game_name, "Game" %>
          <%= form.select :game_name, [
            ["DBZ Dokkan Battle", "dokkan"],
            ["One Piece Treasure Cruise (OPTC)", "optc"],
            ["Game 3", "3"],
            ["Game 4", "4"]] %>
        </div>

        <div class="edit-v2-field">
          <%= form.label :description, "Description (Markdown supported)" %>
          <%= form.textarea :description, placeholder: "Describe the product…" %>
        </div>
      </div>

      <%# ── Checkout ── %>
      <div class="edit-v2-section">
        <div class="edit-v2-section-header">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          Checkout
        </div>

        <div class="edit-v2-row">
          <div class="edit-v2-field">
            <%= form.label :payment_type, "Payment type" %>
            <%= form.select :payment_type, [
              ["Single Payment", "single_payment"],
              ["Subscription", "subscription"],
              ["Pay What You Want", "any"]] %>
          </div>
          <div class="edit-v2-field">
            <%= form.label :deliverables, "Deliverable type" %>
            <%= form.select :deliverables, [
              ["Static Value", "static"],
              ["License Key", "licence"],
              ["Unique Codes & Serials", "serial"]] %>
          </div>
        </div>
      </div>

      <%# ── Variants ── %>
      <div class="edit-v2-section">
        <div class="edit-v2-section-header">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          Variants
        </div>

        <div data-controller="insert-variant">
          <template data-insert-variant-target="template">
            <%= form.fields_for :variants, Variant.new, child_index: "NEW_RECORD" do |variant| %>
              <div class="edit-v2-variant-card">
                <div class="edit-v2-variant-header">
                  <span>New variant</span>
                </div>
                <div class="edit-v2-row">
                  <div class="edit-v2-field">
                    <%= variant.label :title %>
                    <%= variant.text_field :title, placeholder: "e.g. iOS version" %>
                  </div>
                  <div class="edit-v2-field" style="max-width: 100px">
                    <%= variant.label :price, "Price (cents)" %>
                    <%= variant.number_field :price, min: 0, placeholder: "1299" %>
                  </div>
                  <div class="edit-v2-field" style="max-width: 80px">
                    <%= variant.label :stock %>
                    <%= variant.number_field :stock, min: 0 %>
                  </div>
                </div>
              </div>
            <% end %>
          </template>

          <button type="button" data-action="insert-variant#add" class="edit-v2-add-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add variant
          </button>

          <div data-insert-variant-target="container">
            <%= form.fields_for :variants do |variant| %>
              <div class="edit-v2-variant-card">
                <div class="edit-v2-variant-header">
                  <span><%= variant.object.title.presence || "Variant ##{variant.index + 1}" %></span>
                  <label class="edit-v2-image-check">
                    <%= variant.check_box :_destroy %>
                    Remove
                  </label>
                </div>
                <div class="edit-v2-row">
                  <div class="edit-v2-field">
                    <%= variant.label :title %>
                    <%= variant.text_field :title %>
                  </div>
                  <div class="edit-v2-field" style="max-width: 100px">
                    <%= variant.label :price, "Cents" %>
                    <%= variant.number_field :price, min: 0 %>
                  </div>
                  <div class="edit-v2-field" style="max-width: 80px">
                    <%= variant.label :stock %>
                    <%= variant.number_field :stock, min: 0 %>
                  </div>
                </div>
                <div class="edit-v2-field" style="max-width: 200px">
                  <%= variant.label :description %>
                  <%= variant.text_field :description, placeholder: "Short note" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <%# ── Media ── %>
      <div class="edit-v2-section">
        <div class="edit-v2-section-header">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          Images
        </div>

        <div data-controller="insert-image">
          <template data-insert-image-target="template">
            <%= form.fields_for :product_images, ProductImage.new, child_index: "NEW_IMAGE" do |image_form| %>
              <div class="edit-v2-image-card is-new">
                <div class="edit-v2-image-placeholder">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  New image
                </div>
                <div class="edit-v2-image-body">
                  <%= image_form.file_field :image, accept: 'image/png,image/gif,image/jpeg' %>
                  <div style="margin-top: 6px">
                    <label>Priority</label>
                    <%= image_form.number_field :priority, value: 1 %>
                  </div>
                </div>
              </div>
            <% end %>
          </template>

          <div class="edit-v2-images" data-insert-image-target="container">
            <%= form.fields_for :product_images do |image_form| %>
              <div class="edit-v2-image-card">
                <% if image_form.object.image.attached? %>
                  <%= image_tag image_form.object.image, class: "edit-v2-image-preview" %>
                <% else %>
                  <div class="edit-v2-image-placeholder">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    No preview
                  </div>
                <% end %>

                <div class="edit-v2-image-body">
                  <%= image_form.label :image, "Replace image" %>
                  <%= image_form.file_field :image, accept: 'image/png,image/gif,image/jpeg' %>
                  <div style="margin-top: 6px">
                    <label>Priority</label>
                    <%= image_form.number_field :priority, value: image_form.object.priority || 1 %>
                  </div>
                  <label class="edit-v2-image-check">
                    <%= image_form.check_box :_destroy %>
                    Remove this image
                  </label>
                </div>
              </div>
            <% end %>
          </div>

          <button type="button" data-action="insert-image#add" class="edit-v2-add-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add image
          </button>
        </div>
      </div>

    <% end %>
  </div>

  <%# ═══ RIGHT: Live Preview ═══ %>
  <div class="edit-v2-preview">
    <div class="edit-v2-preview-label">Store preview</div>
    <div class="edit-v2-preview-card">
      <% preview_image = @product.product_images.min_by(&:priority) %>
      <% if preview_image&.image&.attached? %>
        <%= image_tag preview_image.image, class: "edit-v2-preview-img" %>
      <% else %>
        <div class="edit-v2-preview-img-placeholder">No image</div>
      <% end %>

      <div class="edit-v2-preview-body">
        <div class="edit-v2-preview-title"><%= @product.title %></div>
        <div class="edit-v2-preview-game"><%= @product.game_name&.titleize || "—" %></div>

        <div class="edit-v2-preview-variants">
          <% @product.variants.each do |v| %>
            <div class="edit-v2-preview-variant">
              <span class="edit-v2-preview-variant-name"><%= v.title %></span>
              <span class="edit-v2-preview-variant-price">
                <%= number_to_currency(v.price.to_f / 100, unit: "€") %>
              </span>
            </div>
          <% end %>
        </div>

        <div class="edit-v2-preview-meta">
          <span><%= @product.visibility == "live" ? "● Live" : "○ Hidden" %></span>
          <span><%= @product.payment_type&.titleize || "—" %></span>
        </div>
      </div>
    </div>
  </div>

</div>
