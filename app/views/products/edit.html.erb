
<% content_for :head do %>
  <%= stylesheet_link_tag "product/product_form" %>
<% end %>

<div class="pf">
  <div class="pf-header">
    <h1>Edit product</h1>
    <p><%= link_to "View product →", product_path(@product), class: "pf-link" %></p>
  </div>

  <% if flash[:fail_edit] %>
    <p class="flash"><%= flash[:fail_edit] %></p>
  <% end %>

  <%= form_with model: @product, multipart: true do |form| %>

    <div class="submit-card">
      <%= form.submit %>
    </div>

    <details open class="card">
      <summary>General</summary>
      <div id="edit-general-section">
        <div class="field">
          <%= form.label :visibility %>
          <%= form.select :visibility,
            [["Live", "live"],
             ["Hidden", "hidden"],
             ["Private", "private"],
             ["On Hold", "on_hold"]] %>
        </div>

        <div class="field">
          <%= form.label :title, "Product title" %>
          <%= form.text_field :title %>
        </div>

        <div class="field" id="edit-description">
          <%= form.label :description %>
          <%= form.textarea :description %>
        </div>
      </div>
    </details>

    <details class="card">
      <summary>Checkout</summary>
      <div id="edit-checkout-section">
        <div class="field">
          <%= form.label :payment_type %>
          <%= form.select :payment_type,
            [ ["Single Payment", "single_payment"],
              ["Subscription", "subscription"],
              ["Pay What You Want", "any"] ] %>
        </div>

        <div class="field">
          <%= form.label :deliverables %>
          <%= form.select :deliverables,
            [ ["Static Value", "static"],
              ["License Key", "licence"],
              ["Unique Codes & Serials", "serial"] ] %>
        </div>
      </div>
    </details>

    <details class="card">
      <summary>Variants</summary>
      <div data-controller="insert-variant" id="edit-variants-section">

        <template data-insert-variant-target="template">
          <%= form.fields_for :variants, Variant.new, child_index: "NEW_RECORD" do |variant| %>
            <div class="sub-card">
              <div class="field">
                <%= variant.label :title %>
                <%= variant.text_field :title %>
              </div>
              <div class="field">
                <%= variant.label :price %>
                <%= variant.number_field :price, min: 0 %>
              </div>
              <div class="field">
                <%= variant.label :stock %>
                <%= variant.number_field :stock, min: 0 %>
              </div>
              <div class="field">
                <%= variant.label :description %>
                <%= variant.textarea :description %>
              </div>
              <div class="field-inline">
                <%= variant.check_box :_destroy %>
                <%= variant.label :_destroy, "Remove this variant" %>
              </div>
            </div>
          <% end %>
        </template>

        <div class="btn-row">
          <button type="button" data-action="insert-variant#add" class="btn-secondary">Add variant</button>
        </div>

        <div data-insert-variant-target="container">
          <%= form.fields_for :variants do |variant| %>
            <div class="sub-card">
              <div class="field">
                <%= variant.label :title %>
                <%= variant.text_field :title %>
              </div>
              <div class="field">
                <%= variant.label :price %>
                <%= variant.number_field :price, min: 0 %>
              </div>
              <div class="field">
                <%= variant.label :stock %>
                <%= variant.number_field :stock, min: 0 %>
              </div>
              <div class="field">
                <%= variant.label :description %>
                <%= variant.textarea :description %>
              </div>
              <div class="field-inline">
                <%= variant.check_box :_destroy %>
                <%= variant.label :_destroy, "Remove this variant" %>
              </div>
            </div>
          <% end %>
        </div>

      </div>
    </details>

    <details open class="card">
      <summary>Media</summary>
      <div data-controller="insert-image" id="edit-media-section">
        <template data-insert-image-target="template">
          <%= form.fields_for :product_images, ProductImage.new, child_index: "NEW_IMAGE" do |image_form| %>
            <div class="sub-card">

              <% if image_form.object.image.attached? %>
                <%= image_tag image_form.object.image, class: "image-preview" %>
                <div class="field">
                  <%= image_form.label :image, "Change Image" %>
                  <%= image_form.file_field :image, accept: 'image/png,image/gif,image/jpeg' %>
                </div>

                <div class="field-inline">
                  <%= image_form.check_box :_destroy %>
                  <%= image_form.label :_destroy, "Remove this image" %>
                </div>

              <% else %>
                <div class="field">
                  <%= image_form.label :image, "Upload Image" %>
                  <%= image_form.file_field :image, accept: 'image/png,image/gif,image/jpeg' %>
                </div>
              <% end %>

              <div class="field">
                <%= image_form.label :priority, "Priority (1 = main)" %>
                <%= image_form.number_field :priority, value: 1 %>
              </div>

            </div>
          <% end %>
        </template>

        <div class="btn-row">
          <button type="button" data-action="insert-image#add" class="btn-secondary">Add additional image</button>
        </div>

        <div data-insert-image-target="container">
          <%= form.fields_for :product_images do |image_form| %>
            <div class="sub-card">

              <% if image_form.object.image.attached? %>
                <%= image_tag image_form.object.image, class: "image-preview" %>
                <div class="field">
                  <%= image_form.label :image, "Change Image" %>
                  <%= image_form.file_field :image, accept: 'image/png,image/gif,image/jpeg' %>
                </div>

                <div class="field-inline">
                  <%= image_form.check_box :_destroy %>
                  <%= image_form.label :_destroy, "Remove this image" %>
                </div>

              <% else %>
                <div class="field">
                  <%= image_form.label :image, "Upload Image" %>
                  <%= image_form.file_field :image, accept: 'image/png,image/gif,image/jpeg' %>
                </div>
              <% end %>

              <div class="field">
                <%= image_form.label :priority, "Priority (1 = main)" %>
                <%= image_form.number_field :priority, value: 1 %>
              </div>

            </div>
          <% end %>
        </div>

      </div>
    </details>

  <% end %>
</div>