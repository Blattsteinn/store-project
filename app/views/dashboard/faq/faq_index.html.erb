<h1>FAQs (Admin)</h1>

<%= link_to "+ New FAQ", new_faq_path, style: "display:inline-block;margin-bottom:1rem;" %>

<table border="1" cellpadding="8" cellspacing="0" style="width:100%;border-collapse:collapse;">
  <thead>
    <tr>
      <th style="text-align:left">#</th>
      <th style="text-align:left">Question</th>
      <th style="text-align:left">Answer</th>
      <th style="text-align:left">Created</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @faqs.each do |faq| %>
      <tr>
        <td><%= faq.id %></td>
        <td><%= faq.question %></td>
        <td><%= faq.answer %></td>
        <td><%= faq.created_at.strftime("%b %d, %Y") %></td>
        <td>
          <%= link_to "Edit", edit_faq_path(faq) %> |
          <%= button_to "Delete", faq_path(faq), method: :delete,
                data: { turbo_confirm: "Delete this FAQ?" },
                style: "background:none;border:none;color:red;cursor:pointer;padding:0;" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>