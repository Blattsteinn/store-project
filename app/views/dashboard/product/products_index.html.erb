<div id="dashboard-container">
  <%= render "dashboard/sidebar" %>

  <main id="dashboard-main">
    <header class="dashboard-page-header">
      <div>
        <h1>Products</h1>
        <p class="text-muted"><%= @products.count %> products</p>
      </div>
      <%= link_to "+ New Product", new_product_path, class: "btn-primary" %>
    </header>

    <% if flash[:successful_edit] %>
      <div class="dash-flash dash-flash-success"><%= flash[:successful_edit] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="dash-flash dash-flash-success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="dash-flash dash-flash-error"><%= flash[:alert] %></div>
    <% end %>

    <div class="dashboard-card">
      <div class="card-body" style="padding: 0;">
        <table class="dash-table dash-table--products">
          <thead>
            <tr>
              <th>Product</th>
              <th>Visibility</th>
              <th>Price</th>
              <th>Stock</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @products.each do |product| %>
              <tr>
                <td>
                  <%= link_to product.title, product_path(product), target: "_blank", class: "product-link" %>
                </td>
                <td>
                  <span class="status-badge status-vis-<%= product.visibility %>">
                    <%= product.visibility == "live" ? "● Live" : "○ Hidden" %>
                  </span>
                </td>
                <td class="mono">
                  <%= product.variants.minimum(:price)&.then { |p| convert_from_cents(p) } || "—" %> €
                </td>
                <td class="mono"><%= product.variants.sum(:stock) %></td>
                <td>
                  <div class="action-group">
                    <%= link_to "Edit", edit_product_path(product), class: "btn-sm" %>
                    <%= link_to "View", product_path(product), target: "_blank", class: "btn-sm btn-sm-muted" %>

                    <%= button_to product.visibility == "live" ? "Hide" : "Unhide",
                        product_visibility_product_path(product), method: :patch,
                        class: "btn-sm btn-sm-muted", form_class: "inline-form" %>

                    <%= button_to "Dup", duplicate_product_product_path(product),
                        method: :post, class: "btn-sm btn-sm-muted", form_class: "inline-form" %>

                    <%= button_to "Delete", product_path(product), method: :delete,
                        class: "btn-sm btn-sm-danger", form_class: "inline-form",
                        data: { turbo_confirm: "Delete #{product.title}?" } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <% if @products.empty? %>
          <p class="empty-state">No products yet. <%= link_to "Create one", new_product_path %>.</p>
        <% end %>
      </div>
    </div>
  </main>
</div>
