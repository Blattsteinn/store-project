<div id="dashboard-container">
  <%= render "dashboard/sidebar" %>

  <main id="dashboard-main">
    <header class="dashboard-page-header">
      <h1>Feedback</h1>
      <p class="text-muted"><%= @feedbacks.count %> entries</p>
    </header>

    <div class="dashboard-card">
      <div class="card-body" style="padding: 0;">
        <% if @feedbacks.any? %>
          <table class="dash-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Rating</th>
                <th>Feedback</th>
                <th>Order</th>
                <th>Date</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @feedbacks.each do |feedback| %>
                <tr>
                  <td class="mono">#<%= feedback.id %></td>
                  <td>
                    <span class="rating-stars"><%= "★" * feedback.rating %><%= "☆" * (5 - feedback.rating) %></span>
                  </td>
                  <td><%= truncate(feedback.feedback, length: 60) %></td>
                  <td>
                    <% if feedback.order_id %>
                      <%= link_to "Order", dashboard_order_path(feedback.order_id), class: "mono-link" %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td><%= feedback.created_at.strftime('%b %d, %Y') %></td>
                  <td>
                    <%= link_to 'View', dashboard_feedback_show_path(feedback), class: "btn-sm" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class="empty-state">No feedback yet.</p>
        <% end %>
      </div>
    </div>
  </main>
</div>