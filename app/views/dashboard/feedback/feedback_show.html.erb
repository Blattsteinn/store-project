<h1> Feedback Details </h1>

<div class="card">
  <div class="card-body">
    <div class="row mb-3">
      <div class="col-md-6">
        <h5>Feedback ID</h5>
        <p><code><%= @feedback.id %></code></p>
      </div>
      <div class="col-md-6">
        <h5>Rating</h5>
        <p>
          <span class="badge badge-success" style="font-size: 1rem;">
            <%= @feedback.rating %>/5 ⭐
          </span>
        </p>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-md-6">
        <h5>User</h5>
        <p><%= @feedback.user&.email || 'N/A' %></p>
      </div>
      <div class="col-md-6">
        <h5>Order</h5>
        <p>
          <% if @feedback.order_id %>
            <%= link_to @feedback.order_id, dashboard_order_path(@feedback.order_id) %>
          <% else %>
            <span class="text-muted">N/A</span>
          <% end %>
        </p>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-md-6">
        <h5>Created At</h5>
        <p><%= @feedback.created_at.strftime('%B %d, %Y at %I:%M %p') %></p>
      </div>
      <div class="col-md-6">
        <h5>Updated At</h5>
        <p><%= @feedback.updated_at.strftime('%B %d, %Y at %I:%M %p') %></p>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-12">
        <h5>Feedback</h5>
        <p class="bg-light p-3 rounded"><%= simple_format(@feedback.feedback) %></p>
      </div>
    </div>
  </div>
</div>

<div class="mt-3">
  <%= link_to 'Back to Feedbacks', dashboard_feedbacks_path, class: 'btn btn-secondary' %>
</div>

<div>
   <%= button_to "Delete it", feedback_path(@feedback), method: :delete  %>
   <%= link_to "Edit it", edit_feedback_path(@feedback)  %>
</div>