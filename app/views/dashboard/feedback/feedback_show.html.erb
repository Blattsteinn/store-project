<div id="dashboard-container">
  <%= render "dashboard/sidebar" %>

  <main id="dashboard-main">
    <header class="dashboard-page-header">
      <div>
        <h1>Feedback #<%= @feedback.id %></h1>
        <p class="text-muted"><%= @feedback.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>
      <span class="rating-stars" style="font-size: 1.25rem;">
        <%= "★" * @feedback.rating %><%= "☆" * (5 - @feedback.rating) %>
      </span>
    </header>

    <div class="dashboard-grid">
      <div class="dashboard-card">
        <div class="card-header"><h3>Details</h3></div>
        <div class="card-body">
          <dl class="detail-list">
            <div class="detail-row">
              <dt>Rating</dt>
              <dd><span class="rating-stars"><%= "★" * @feedback.rating %><%= "☆" * (5 - @feedback.rating) %></span> (<%= @feedback.rating %>/5)</dd>
            </div>
            <div class="detail-row">
              <dt>Order</dt>
              <dd>
                <% if @feedback.order_id %>
                  <%= link_to "Order ##{@feedback.order.public_id&.first(12)}", dashboard_order_path(@feedback.order_id), class: "mono-link" %>
                <% else %>
                  <span class="text-muted">N/A</span>
                <% end %>
              </dd>
            </div>
            <div class="detail-row">
              <dt>Created</dt>
              <dd><%= @feedback.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
            </div>
          </dl>
        </div>
      </div>

      <div class="dashboard-card">
        <div class="card-header"><h3>Actions</h3></div>
        <div class="card-body">
          <div class="action-group" style="flex-direction: column; align-items: flex-start; gap: 0.5rem;">
            <%= link_to "Edit", edit_feedback_path(@feedback), class: "btn-sm" %>
            <%= button_to "Delete", feedback_path(@feedback), method: :delete,
                class: "btn-sm btn-sm-danger",
                data: { turbo_confirm: "Delete this feedback?" } %>
          </div>
        </div>
      </div>
    </div>

    <div class="dashboard-card">
      <div class="card-header"><h3>Message</h3></div>
      <div class="card-body">
        <div class="feedback-body"><%= simple_format(@feedback.feedback) %></div>
      </div>
    </div>

    <div style="margin-top: 1rem;">
      <%= link_to "← Back to Feedback", dashboard_feedbacks_path, class: "btn-sm btn-sm-muted" %>
    </div>
  </main>
</div>