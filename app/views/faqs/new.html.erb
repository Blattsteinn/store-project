<% content_for :head do %>
  <%= stylesheet_link_tag "faqs" %>
<% end %>

<div class="faq-form">
  <div class="faq-header">
    <h1>New FAQ</h1>
  </div>

  <%= form_with model: @faq do |form| %>
    <div class="card">
      <div class="field">
        <%= form.label :question %>
        <%= form.text_field :question %>
      </div>

      <div class="field">
        <%= form.label :answer %>
        <%= form.textarea :answer %>
      </div>
    </div>

    <div class="submit-row">
      <%= form.submit "Create FAQ" %>
    </div>
  <% end %>
</div>