<% content_for :head do %>
  <%= stylesheet_link_tag "faqs" %>
<% end %>

<div class="faq">
  <div class="faq-header">
    <h1>Frequently Asked Questions</h1>
  </div>

  <% if @faqs.any? %>
    <% @faqs.each do |faq| %>
      <div class="card">
        <dt><%= faq.question %></dt>
        <dd><%= faq.answer %></dd>
      </div>
    <% end %>
  <% else %>
    <p class="faq-empty">No FAQs available yet.</p>
  <% end %>

  <% if current_user&.admin? %>
    <%= link_to "Manage FAQs (Admin) →", dashboard_faqs_path, class: "faq-admin-link" %>
  <% end %>
</div>