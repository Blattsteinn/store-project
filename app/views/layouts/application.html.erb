<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dokkan Store" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Dokkan Store">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% flash.each do |type, message| %>
      <div class="flash <%= type %>"><%= message %></div>
    <% end %>
    <nav>
      <%= link_to "Dokkan Store", root_path, class: "nav-brand" if Rails.application.routes.url_helpers.respond_to?(:root_path) %>
      <%= link_to "Products", products_path %>
      <%= link_to "Orders", orders_path %>
      <%= link_to "Dashboard", dashboard_path %>
      <%= link_to "Support (TBD)" %>
      <%= link_to "Feedback (TBD)" %>

      <div class="nav-right">
        <% if user_signed_in? %>
          <span class="nav-user"><%= current_user.email %> (<%= current_user.admin? ? "admin" : "user" %>)</span>
          <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete } %>
        <% else %>
          <%= link_to "Sign In", new_user_session_path %>
        <% end %>

        <%= link_to cart_path, class: "nav-cart" do %>
          <%= image_tag '/assets/cart-outline.svg', class: 'cart-icon' %>
          <turbo-frame id="cart-counter">
            <p><%= session[:cart]&.length || 0 %></p>
          </turbo-frame>
        <% end %>
      </div>
    </nav>
    <%= yield %>
  </body>
</html>
