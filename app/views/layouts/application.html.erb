<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Account Rift" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Account Rift">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" href="/favicon.ico" type="image/x-icon" sizes="48x48">
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= controller_name %>-<%= action_name %>">



    <% if user_signed_in? %>
      <nav class="<%= controller_name %>-<%= action_name %>">
        <%= link_to "Products", products_path %>
        <%= link_to "Support", new_support_message_path %>
        <%= link_to "Feedback", feedbacks_path %>
        <%= link_to "FAQ", faqs_path %>
        
        <% if current_user.admin? %>
          <%= link_to "Dashboard", dashboard_path %>
        <% end %>

        
          <div class="nav-right">
            
              <span class="nav-user"><%= current_user.email %> (<%= current_user.admin? ? "admin" : "user" %>)</span>
              <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete } %>
              <%= link_to "Sign In", new_user_session_path %>
            

          </div>
        
      </nav>

    <% else %>

      <%# Display this if not signed in %>

      <nav class="<%= controller_name %>-<%= action_name %>">
        <%= link_to "Products", products_path %>
        <%= link_to "Support", new_support_message_path %>
        <%= link_to "Feedback", feedbacks_path %>
        <%= link_to "FAQ", faqs_path %>

      </nav>

    <% end %>

       <% flash.each do |type, message| %>
      <div class="alert alert-danger">
              <%= message %>
      </div>
    <% end %>
        
    <%= yield %>
    
    <footer class="site-footer">
      <span>&copy; <%= Time.current.year %> Account Rift</span>
      <%= link_to "Terms of Service", tos_path %>
      <%= link_to "Privacy Policy", privacy_path %>
    </footer>
  </body>
</html>
