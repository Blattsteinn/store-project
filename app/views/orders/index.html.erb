
<h2> My orders </h2>

<% unless @orders.nil? %>
    <% @orders.each do |order| %>
        <h2> <%= order.id %> </h2>
            <ul>
            <% order.order_items.each do |item| %>
               <li> <%= item.product.title %> </li>
            <% end %>
            </ul>
    <% end %>
<% else %>
    <p> No orders! </p>
<% end %>