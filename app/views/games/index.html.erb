

<div id="games-index-page">

  <div id="games-banner">
    <div class="banner-overlay">
      <h1 class="banner-title">Account Rift</h1>
      <p class="banner-subtitle">Premium game accounts — safe, fast, and trusted by thousands of gamers worldwide.</p>
      <p class="banner-discord">Discord: @dokkanarnis</p>
    </div>
  </div>

  <% if @games.any? %>
    <div class="games-section-header">
      <h2>Choose Your Game</h2>
      <p>Select a game to browse available accounts</p>
    </div>

    <div id="games-container">
      <% @games.each do |game| %>
        <%= link_to game_products_path(game.name), class: "game-card" do %>
          <div class="game-card-image">
            <%= image_tag "#{game.name}.png", alt: game.official_name, onerror: "this.style.display='none'" %>
          </div>
          <span class="game-card-name"><%= game.official_name %></span>
          <span class="game-card-hint">Browse Accounts →</span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div id="games-container">
      <div class="empty-state">
        <p class="empty-state-icon">🎮</p>
        <p class="empty-state-text">No games available yet</p>
        <p class="empty-state-hint">Check back soon — new games are on the way!</p>
      </div>
    </div>
  <% end %>

</div>
